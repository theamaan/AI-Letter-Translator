# AI Letter Translator — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to source control.

# ── Cerebras API ────────────────────────────────────────────────────────────
# Required. Obtain from https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Ollama (local open-source LLM) ──────────────────────────────────────────
# Set to false to route all traffic through Cerebras only.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
# Seconds to wait for an Ollama response (large models can be slow).
OLLAMA_TIMEOUT=120

# ── Routing mode ────────────────────────────────────────────────────────────
# hybrid        — Ollama for analysis + simple translations; Cerebras for complex
# ollama-only   — Ollama for all tasks (falls back to Cerebras on failure)
# cerebras-only — Cerebras for all tasks (original single-model behaviour)
ROUTING_MODE=hybrid

# ── Paragraph batching ──────────────────────────────────────────────────────
# Paragraphs shorter than BATCH_THRESHOLD characters are grouped into batch
# API calls to avoid repeating the system prompt for every short line.
BATCH_THRESHOLD=200
BATCH_SIZE=5
